# ── Required ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# Choose a strong password — the default "admin" will be rejected at startup
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Database credentials — change from defaults for any non-dev deployment
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://gatekeeper:REPLACE_WITH_STRONG_DB_PASSWORD@db:5432/gatekeeper

# ── AI (BYOK — at least one required for AI features) ─────────────────────────
# Anthropic (default provider) — configure via Settings UI or env var
ANTHROPIC_API_KEY=

# OpenAI (set ai_provider=openai in Settings)
# OPENAI_API_KEY=

# ── Notifications (optional) ──────────────────────────────────────────────────
# SendGrid email
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# NOTIFY_EMAIL=

# Telegram bot
# TELEGRAM_BOT_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost

# ── Development only ──────────────────────────────────────────────────────────
# Set to "1" to skip startup security checks (NEVER set in production)
# SKIP_SECURITY_CHECKS=1
