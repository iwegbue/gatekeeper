# ── First-run setup ────────────────────────────────────────────────────────────
# Both of these are optional for the default Docker Compose setup.
#
# SECRET_KEY — auto-generated and persisted to /data/secret_key on first run.
#   Set this explicitly only if you need sessions to survive container recreation
#   without the /data volume (e.g. scripted/CI deployments).
# SECRET_KEY=

# ADMIN_PASSWORD — set via the /setup wizard in your browser on first run.
#   Set this here to skip the wizard (useful for scripted deployments).
# ADMIN_PASSWORD=

# ── Database ───────────────────────────────────────────────────────────────────
# Change POSTGRES_PASSWORD if exposing the DB port externally.
# The app DATABASE_URL is wired automatically in docker-compose.yml.
# POSTGRES_PASSWORD=gatekeeper

# ── AI (BYOK — configure via Settings UI after first login) ───────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Notifications (optional) ──────────────────────────────────────────────────
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# NOTIFY_EMAIL=
# TELEGRAM_BOT_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost

# ── Development only ──────────────────────────────────────────────────────────
# Set to "1" to skip startup security checks (NEVER set in production)
# SKIP_SECURITY_CHECKS=1
