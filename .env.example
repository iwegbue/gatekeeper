# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gatekeeper:gatekeeper@db:5432/gatekeeper
ADMIN_PASSWORD=changeme

# ── AI (BYOK — at least one required for AI features) ─────────────────────────
# Anthropic (default provider)
ANTHROPIC_API_KEY=

# OpenAI (set ai_provider=openai in Settings)
# OPENAI_API_KEY=

# Ollama (set ai_provider=ollama in Settings, base URL in Settings UI)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Notifications (optional) ──────────────────────────────────────────────────
# SendGrid email
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# NOTIFY_EMAIL=

# Telegram bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
APP_BASE_URL=http://localhost
